set $mod Mod4
set $sec Mod1

font pango:Hack 13

# exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork -c 333333
exec --no-startup-id xsetroot -solid "#333"

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

# todo: brightness
# todo: cycle workspaces
bindsym $mod+Tab workspace back_and_forth

floating_modifier $mod
workspace_auto_back_and_forth yes

bindsym $mod+space exec --no-startup-id i3-dmenu-desktop --dmenu="dmenu -i -p open -fn Hack:size=13"
bindsym $mod+p exec --no-startup-id /usr/share/doc/pass/examples/dmenu/passmenu -i -p pass -fn Hack:size=13
bindsym $mod+Return exec gnome-terminal --profile=i3wm

# bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
# bindsym $mod+l focus right

bindsym $mod+$sec+h move left
bindsym $mod+$sec+j move down
bindsym $mod+$sec+k move up
bindsym $mod+$sec+l move right

bindsym $mod+x move workspace to output next
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+a focus parent
bindsym $mod+d focus child
bindsym $mod+o focus next
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+c kill

bindsym $mod+$sec+r restart
bindsym $mod+$sec+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+$sec+space floating toggle

set $wss "~"
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws0 "0"

bindsym $mod+grave workspace number $wss
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws0

bindsym $mod+$sec+1 move container to workspace number $ws1
bindsym $mod+$sec+2 move container to workspace number $ws2
bindsym $mod+$sec+3 move container to workspace number $ws3
bindsym $mod+$sec+4 move container to workspace number $ws4
bindsym $mod+$sec+5 move container to workspace number $ws5
bindsym $mod+$sec+6 move container to workspace number $ws6
bindsym $mod+$sec+7 move container to workspace number $ws7
bindsym $mod+$sec+8 move container to workspace number $ws8
bindsym $mod+$sec+9 move container to workspace number $ws9
bindsym $mod+$sec+0 move container to workspace number $ws0

bindsym $mod+r mode "resize"
mode "resize" {
	bindsym h resize shrink width 5 px or 5 ppt
	bindsym j resize grow height 5 px or 5 ppt
	bindsym k resize shrink height 5 px or 5 ppt
	bindsym l resize grow width 5 px or 5 ppt

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

bindsym $mod+Escape mode "system"
mode "system" {
	bindsym e i3-msg exit
	bindsym r systemctl reboot
	bindsym s systemctl suspend
	bindsym p systemctl poweroff

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

bar {
	status_command i3status
	tray_output none
}
