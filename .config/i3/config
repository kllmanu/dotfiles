set $mod Mod4
set $sec Mod1

font pango:Hack 13

exec --no-startup-id xinput --set-prop "TPPS/2 Elan TrackPoint" "libinput Accel Speed" 1.0
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork -c 333333
exec --no-startup-id xsetroot -solid "#333"
exec --no-startup-id xmodmap ~/.Xmodmap

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym XF86MonBrightnessDown exec --no-startup-id xbacklight -dec 5
bindsym XF86MonBrightnessUp exec --no-startup-id xbacklight -inc 5

floating_modifier $mod
workspace_auto_back_and_forth yes
default_orientation auto
# for_window [all] title_window_icon yes

bindsym $mod+space exec --no-startup-id i3-dmenu-desktop --dmenu="dmenu -i -p open -fn Hack:size=13"
bindsym $mod+p exec --no-startup-id /usr/share/doc/pass/examples/dmenu/passmenu -i -p pass -fn Hack:size=13
bindsym $mod+Return exec gnome-terminal --profile=i3wm

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+$sec+h move left
bindsym $mod+$sec+j move down
bindsym $mod+$sec+k move up
bindsym $mod+$sec+l move right

bindsym $mod+Tab workspace back_and_forth
bindsym $mod+x move workspace to output next
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen toggle
bindsym $mod+a focus parent
bindsym $mod+d focus child
bindsym $mod+o focus next
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+c kill

bindsym $mod+$sec+r restart
bindsym $mod+$sec+space floating toggle

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 0

bindsym $mod+$sec+1 move container to workspace number 1
bindsym $mod+$sec+2 move container to workspace number 2
bindsym $mod+$sec+3 move container to workspace number 3
bindsym $mod+$sec+4 move container to workspace number 4
bindsym $mod+$sec+5 move container to workspace number 5
bindsym $mod+$sec+6 move container to workspace number 6
bindsym $mod+$sec+7 move container to workspace number 7
bindsym $mod+$sec+8 move container to workspace number 8
bindsym $mod+$sec+9 move container to workspace number 9
bindsym $mod+$sec+0 move container to workspace number 0

bindsym $mod+r mode "resize"
mode "resize" {
	bindsym h resize shrink width 5 px or 5 ppt
	bindsym j resize grow height 5 px or 5 ppt
	bindsym k resize shrink height 5 px or 5 ppt
	bindsym l resize grow width 5 px or 5 ppt

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

bindsym $mod+Escape mode "system"
mode "system" {
	bindsym e exec --no-startup-id i3-msg exit
	bindsym r exec --no-startup-id systemctl reboot
	bindsym s exec --no-startup-id systemctl suspend
	bindsym p exec --no-startup-id systemctl poweroff

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

bar {
	status_command i3status
	tray_output none
}

for_window [instance="libreoffice"] move container to workspace 2
for_window [class="(?i)chrome|firefox|edge|emacs"] border none
assign [class="(?i)chrome|firefox|edge|qutebrowser"] 1
assign [class="(?i)pcmanfm|thunar|packettracer"] 2
assign [class="(?i)emacs"] 3
assign [class="(?i)steam|discord"] 8
